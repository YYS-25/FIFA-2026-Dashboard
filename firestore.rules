// Firestore security rules for the FIFA 2026 dashboard bracket predictions
// feature. Paste into Firebase console -> Firestore Database -> Rules (or
// deploy with `firebase deploy --only firestore:rules` if using the CLI).
//
// Threat model: this protects a 5-person friend-group bracket pool, not a
// public product - the goal is to stop casual impersonation (someone
// submitting picks under a friend's name) and to make submissions provably
// immutable, not to defend against a determined attacker.
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Admin-seeded PIN hashes, one per person. Seeded manually via the
    // Firebase console before the feature goes live - never written by
    // clients. Not directly readable by clients either; only read
    // server-side (i.e. by these rules, via get()) to validate a
    // bracketPredictions submission below.
    match /pins/{person} {
      allow read: if false;
      allow write: if false;
    }

    // One doc per person, created exactly once at final submission and
    // never modified afterward. This is the Round of 32 round - now closed
    // (no new docs expected here) and kept as-is, untouched, for history.
    // Round of 16 predictions live in their own sibling collection below
    // (bracketPredictionsR16) rather than reusing this one, since a person's
    // doc here is already immutable - a fresh round needs a fresh collection
    // to allow a fresh "create".
    match /bracketPredictions/{person} {
      // Predictions are public once locked, same as the rest of the
      // dashboard already shows everyone's predictions/scores openly.
      allow read: if true;

      allow create: if
        request.resource.data.person == person &&
        request.resource.data.pinHash is string &&
        request.resource.data.pinHash ==
          get(/databases/$(database)/documents/pins/$(person)).data.pinHash &&
        isValidPredictionsMap(request.resource.data.predictions) &&
        request.time < deadline();

      allow update, delete: if false;
    }

    // Round of 16 (match_89-96). Same one-doc-per-person, create-once,
    // immutable pattern as bracketPredictions above, in its own collection.
    // Each match's prediction entry may additionally carry a
    // predictedPenaltyWinner ("home"/"away") when its scores are equal - not
    // validated in detail here, same looseness as isValidPredictionsMap
    // below, consistent with this file's stated threat model.
    match /bracketPredictionsR16/{person} {
      allow read: if true;

      allow create: if
        request.resource.data.person == person &&
        request.resource.data.pinHash is string &&
        request.resource.data.pinHash ==
          get(/databases/$(database)/documents/pins/$(person)).data.pinHash &&
        isValidR16PredictionsMap(request.resource.data.predictions) &&
        request.time < r16Deadline();

      allow update, delete: if false;
    }

    // Round config for QF onward - one small doc per round ({deadline,
    // matchCount}). Auto-published by app.js the first time anyone loads the
    // dashboard after that round's matches are fully decided (see
    // autoPublishReadyRoundConfigs in app.js) - no admin step at all. Any
    // client can create one (not an admin-only write like pins/{person}
    // above), but only once per round: matchCount is checked against the
    // fixed, known-in-advance count for that round, deadline must be a real
    // timestamp, and it's immutable afterward - so a stray/race write can't
    // do worse than publish a shape-valid doc once, matching this file's
    // stated threat model (friends, not an attacker).
    function expectedMatchCountForRound(round) {
      return round == 'qf' ? 4 :
             round == 'sf' ? 2 :
             round == 'thirdPlace' ? 1 :
             round == 'final' ? 1 : -1;
    }

    match /roundConfig/{round} {
      allow read: if true;

      allow create: if
        expectedMatchCountForRound(round) > 0 &&
        request.resource.data.matchCount == expectedMatchCountForRound(round) &&
        request.resource.data.deadline is timestamp;

      allow update, delete: if false;
    }

    // Generic collection for QF onward - one doc per (round, person), id
    // "{round}_{person}" (e.g. "qf_Kunal"), since a person's doc is
    // immutable once created and each round needs its own doc. Validated
    // against the matching roundConfig/{round} doc instead of a hardcoded
    // per-round function, so this block never needs to change again.
    match /bracketPredictionsByRound/{docId} {
      allow read: if true;

      allow create: if
        docId == request.resource.data.round + '_' + request.resource.data.person &&
        request.resource.data.pinHash is string &&
        request.resource.data.pinHash ==
          get(/databases/$(database)/documents/pins/$(request.resource.data.person)).data.pinHash &&
        request.resource.data.predictions.size() ==
          get(/databases/$(database)/documents/roundConfig/$(request.resource.data.round)).data.matchCount &&
        request.time <
          get(/databases/$(database)/documents/roundConfig/$(request.resource.data.round)).data.deadline;

      allow update, delete: if false;
    }

    // Submission deadline: 2026-07-01T19:00:00Z (23:00 GMT+4). R32 - historical.
    function deadline() {
      return timestamp.date(2026, 7, 1) + duration.value(68400, 's'); // 19:00:00 UTC
    }

    // Checks that predictions is a map with exactly the Round of 32 round's
    // match keys (remaining Round of 32: match_80-88; match_73-79 are admin-
    // filled). Historical - round is closed, kept for reference.
    function isValidPredictionsMap(p) {
      return p.size() == 9 &&
        p.keys().hasAll([
          'match_80', 'match_81', 'match_82',
          'match_83', 'match_84', 'match_85',
          'match_86', 'match_87', 'match_88'
        ]);
    }

    // Round of 16 submission deadline: reopened to 2026-07-16T00:00:00Z to
    // give Kunal and Anisha a window to submit - R16 matches are already
    // over by this point, so this is purely a straggler submission window,
    // not a real prediction deadline. Safe: everyone who already submitted
    // is still locked out of resubmitting by "allow update, delete: if false"
    // below - this only opens the *create* path for people without a doc yet.
    function r16Deadline() {
      return timestamp.date(2026, 7, 16);
    }

    // Round of 16 = match_89..match_96 (8 matches). Historical - kept as-is;
    // every round from QF onward is validated generically via
    // bracketPredictionsByRound + roundConfig above instead.
    function isValidR16PredictionsMap(p) {
      return p.size() == 8 &&
        p.keys().hasAll([
          'match_89', 'match_90', 'match_91', 'match_92',
          'match_93', 'match_94', 'match_95', 'match_96'
        ]);
    }
  }
}
